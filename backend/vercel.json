{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "methods": ["OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "https://promptshield-web-coral.vercel.app",
        "Access-Control-Allow-Methods": "GET,OPTIONS,PATCH,DELETE,POST,PUT",
        "Access-Control-Allow-Headers": "Content-Type, Authorization, X-Request-ID",
        "Access-Control-Allow-Credentials": "true",
        "Access-Control-Max-Age": "86400"
      },
      "status": 204
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "PYTHONPATH": "/var/task",
    "SECRET_KEY": "your-secret-key-here-set-in-vercel-dashboard",
    "ALGORITHM": "HS256",
    "ACCESS_TOKEN_EXPIRE_MINUTES": "30",
    "REFRESH_TOKEN_EXPIRE_DAYS": "7",
    "ML_DETECTION_ENABLED": "true",
    "DEFAULT_RISK_THRESHOLD": "60",
    "CACHE_SIZE": "1000",
    "TRUSTED_HOSTS": "promptshield-api-topaz.vercel.app,localhost,127.0.0.1",
    "FRONTEND_URL": "https://promptshield-web-coral.vercel.app",
    "ALLOWED_ORIGINS": "https://promptshield-web-coral.vercel.app,http://localhost:3000,http://localhost:5173",
    "ENVIRONMENT": "production",
    "DEBUG": "false"
  }
}
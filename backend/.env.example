# Backend API Configuration
# Database
DATABASE_URL=postgresql://promptshield:password@localhost:5432/promptshield
# For SQLite (development): sqlite:///./promptshield.db

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# Detection
ML_DETECTION_ENABLED=true
DEFAULT_RISK_THRESHOLD=60
CACHE_SIZE=1000

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8001"]

# Environment
ENVIRONMENT=development
DEBUG=true

# API
API_TITLE=PromptShield API
API_VERSION=1.0.0
